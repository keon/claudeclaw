{
  "name": "claude-claw",
  "version": "0.1.0",
  "description": "Telegram-native Claude Code agent harness for Bun",
  "license": "MIT",
  "private": false,
  "packageManager": "bun@1.3.9",
  "type": "module",
  "engines": {
    "bun": ">=1.3.5"
  },
  "bin": {
    "claude-claw": "bin/claude-claw"
  },
  "keywords": [
    "telegram",
    "bot",
    "claude",
    "anthropic",
    "grammy",
    "bun",
    "agent",
    "claude-code"
  ],
  "files": [
    "bin",
    "src",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "check": "bun test && bun run typecheck",
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "grammy": "1.41.1"
  }
}
